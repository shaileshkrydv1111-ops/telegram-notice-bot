# Telegram bot credentials (get the token from @BotFather)
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenReplaceMe
# Chat/channel/group ID that should receive notices (use @userinfobot to find your chat id)
TELEGRAM_CHAT_ID=123456789

# How often to check the websites, in seconds (default: 300 = 5 minutes)
CHECK_INTERVAL_SECONDS=300

# HTTP request timeout in seconds
REQUEST_TIMEOUT_SECONDS=30

# Max retries per HTTP request before giving up on that attempt
MAX_RETRIES=4

# Base delay (seconds) for exponential backoff between retries
RETRY_BACKOFF_SECONDS=5

# Path to the JSON file used to track already-sent notices
DATABASE_FILE=database.json

# Path to the log file
LOG_FILE=logs/bot.log

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# DPI used when rendering PDF pages to images (higher = sharper but larger files)
PDF_RENDER_DPI=200
